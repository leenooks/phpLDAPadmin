APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false

LOG_CHANNEL=daily

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

LDAP_HOST=
LDAP_USERNAME=
LDAP_PASSWORD=
# Obfuscation scheme used for LDAP_PASSWORD: none (default) or sss (SSSD's sss_obfuscate(8) format)
LDAP_PASSWORD_OBFUSCATION=none
LDAP_CACHE=false
LDAP_ALERT_ROOTDN=true
